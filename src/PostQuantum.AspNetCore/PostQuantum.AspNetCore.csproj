<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!--
      net10.0 only. The underlying PostQuantum.Jwt engine relies on the BCL
      System.Security.Cryptography.MLDsa / MLKem types introduced in .NET 10,
      so multi-targeting older TFMs would be dishonest until the engine
      grows a polyfill path. Tracked in KNOWN-GAPS.md.
    -->
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>PostQuantum.AspNetCore</RootNamespace>
    <AssemblyName>PostQuantum.AspNetCore</AssemblyName>
    <IsTrimmable>true</IsTrimmable>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <!-- NuGet package metadata -->
  <PropertyGroup>
    <PackageId>PostQuantum.AspNetCore</PackageId>
    <Version>1.0.0-preview.3</Version>
    <Title>PostQuantum.AspNetCore — post-quantum JWT authentication for ASP.NET Core</Title>
    <Authors>Paul Clark</Authors>
    <Description>The high-level ASP.NET Core integration for post-quantum JWT authentication. Add one line — AddPostQuantumJwtBearer() — and hybrid ML-DSA-65 + X-Wing tokens authenticate through the standard ASP.NET Core pipeline exactly the way AddJwtBearer always has: same AuthenticationBuilder, same [Authorize], same ClaimsPrincipal. Fail-closed by construction, AOT-compatible, observable via System.Diagnostics (Metrics + ActivitySource). This is the application-layer wiring (handler, options, four event hooks, JWKS-equivalent key ring, hosted-service warmup) — NOT a cryptography library. The actual ML-DSA / X-Wing / AES-GCM work happens in PostQuantum.Jwt and the .NET 10 BCL primitives; we sit on top of them. Distributed single-use-jti enforcement available via the companion PostQuantum.AspNetCore.RedisReplayCache package. Preview release — the API surface is what we expect to ship in 1.0; the cryptographic construction is not yet independently audited. See KNOWN-GAPS.md before depending on this for anything that matters.</Description>
    <PackageProjectUrl>https://github.com/systemslibrarian/postquantum-aspnetcore</PackageProjectUrl>
    <RepositoryUrl>https://github.com/systemslibrarian/postquantum-aspnetcore</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>jwt;jose;authentication;jwtbearer;aspnetcore;post-quantum;pqc;ml-dsa;ml-kem;x-wing;hybrid;quantum-resistant;net10</PackageTags>
    <PackageReleaseNotes>1.0.0-preview.3: Suite-reconciliation + integration-hardening release. (1) Suite version reconciliation — PostQuantum.Jwt engine dependency moves to 1.0.0-preview.1 to align with the wider PostQuantum.* ecosystem; no source-level API change vs 1.0.0-preview.2. (2) Trust-root documentation — SECURITY.md gains an explicit "Trust root: the HTTP key directory" section telling operators that the HTTPS key-directory endpoint is the root of trust for token validation and SHOULD be protected with certificate pinning or a hardened HttpClient. (3) AddPostQuantumJwtKeyRing(...) gains an optional configureHttpClient hook so wiring a pinned HttpMessageHandler is the obvious path, not a fork. (4) Bounded key-directory response — the DI helper now caps the typed HttpClient at MaxResponseContentBufferSize=1MB; manual constructors get an optional maxResponseBytes parameter (default unchanged). (5) Unknown-kid flood mitigation — Resolve now short-circuits via a bounded short-TTL negative cache before the sync-over-async bridge; a kid which becomes valid is wrongly rejected for at most 10 seconds, matching the pre-existing forced-refresh throttle (no regression to that bound). No change to fail-closed behaviour, no change to the single-suite policy. Full suite green. See KNOWN-GAPS.md and VERSION-RECONCILIATION.md. Full notes: https://github.com/systemslibrarian/postquantum-aspnetcore/blob/main/CHANGELOG.md.</PackageReleaseNotes>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <Copyright>Copyright © Paul Clark</Copyright>
    <NeutralLanguage>en-US</NeutralLanguage>
  </PropertyGroup>

  <!-- Symbols + SourceLink for debuggable, reproducible packages.
       EnablePackageValidation catches accidental API breaks on subsequent versions. -->
  <PropertyGroup>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <EnablePackageValidation>true</EnablePackageValidation>
    <!-- API-surface baseline check. Opt-in via `-p:EnableBaselineValidation=true`
         once 0.1.0-preview.1 is on nuget.org; until then the pack would fail
         because the baseline package can't be resolved. Local builds and the
         default CI runs deliberately leave this off. -->
    <PackageValidationBaselineVersion Condition="'$(EnableBaselineValidation)' == 'true'">0.1.0-preview.1</PackageValidationBaselineVersion>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <InternalsVisibleTo Include="PostQuantum.AspNetCore.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="PostQuantum.Jwt" Version="1.0.0-preview.1" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="\" />
    <None Include="../../LICENSE" Pack="true" PackagePath="\" />
    <None Include="../../CHANGELOG.md" Pack="true" PackagePath="\" Condition="Exists('../../CHANGELOG.md')" />
  </ItemGroup>

  <!-- Generate a CycloneDX SBOM (bom.json) inside the package on every Pack.
       Requires the `dotnet-CycloneDX` global tool (install via
       `dotnet tool install` with the `global` flag and id `CycloneDX`).
       If the tool isn't present (e.g. a fresh dev machine), pack
       continues without the SBOM rather than failing; the release
       workflow installs the tool unconditionally, so CI always produces
       the SBOM.

       The bom.json is added to the package via an in-target ItemGroup
       because $(IntermediateOutputPath)bom.json doesn't exist at the
       time a static None Include would be evaluated. -->
  <Target Name="GenerateCycloneDxSbom"
          BeforeTargets="GenerateNuspec;_GetPackageFiles"
          Condition="'$(IsPackable)' != 'false'">
    <Exec Command="dotnet CycloneDX &quot;$(MSBuildProjectFullPath)&quot; --output &quot;$(IntermediateOutputPath.TrimEnd('\').TrimEnd('/'))&quot; --filename bom.json --json"
          IgnoreExitCode="true"
          ContinueOnError="WarnAndContinue">
      <Output TaskParameter="ExitCode" PropertyName="_CycloneDxExitCode" />
    </Exec>
    <Message Importance="high"
             Text="CycloneDX SBOM not generated (tool missing or failed, exit=$(_CycloneDxExitCode)). Install with: dotnet tool install (global, id=CycloneDX)."
             Condition="'$(_CycloneDxExitCode)' != '0'" />
    <ItemGroup Condition="Exists('$(IntermediateOutputPath)bom.json')">
      <None Include="$(IntermediateOutputPath)bom.json" Pack="true" PackagePath="\" />
    </ItemGroup>
    <Message Importance="high"
             Text="CycloneDX SBOM packed into .nupkg at /bom.json"
             Condition="Exists('$(IntermediateOutputPath)bom.json')" />
  </Target>

</Project>
