{
  "stryker-config": {
    "project": "src/PostQuantum.AspNetCore/PostQuantum.AspNetCore.csproj",
    "test-projects": [
      "tests/PostQuantum.AspNetCore.Tests/PostQuantum.AspNetCore.Tests.csproj"
    ],
    "reporters": ["progress", "html", "cleartext"],
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 60
    },
    "mutate": [
      "src/PostQuantum.AspNetCore/**/*.cs",
      "!src/PostQuantum.AspNetCore/AssemblyInfo.cs",
      "!src/PostQuantum.AspNetCore/Logging.cs"
    ],
    "ignore-methods": [
      "ArgumentNullException.ThrowIfNull",
      "ArgumentException.ThrowIfNullOrEmpty",
      "ObjectDisposedException.ThrowIf"
    ],
    "coverage-analysis": "off",
    "language-version": "latest"
  }
}
