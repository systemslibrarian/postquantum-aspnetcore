<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!--
      net10.0 only. The underlying PostQuantum.Jwt engine relies on the BCL
      System.Security.Cryptography.MLDsa / MLKem types introduced in .NET 10,
      so multi-targeting older TFMs would be dishonest until the engine
      grows a polyfill path. Tracked in KNOWN-GAPS.md.
    -->
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>PostQuantum.AspNetCore</RootNamespace>
    <AssemblyName>PostQuantum.AspNetCore</AssemblyName>
    <IsTrimmable>true</IsTrimmable>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <!-- NuGet package metadata -->
  <PropertyGroup>
    <PackageId>PostQuantum.AspNetCore</PackageId>
    <Version>1.0.0</Version>
    <Title>PostQuantum.AspNetCore — post-quantum JWT authentication for ASP.NET Core</Title>
    <Authors>Paul Clark</Authors>
    <Description>The high-level ASP.NET Core integration for post-quantum JWT authentication. Add one line — AddPostQuantumJwtBearer() — and hybrid ML-DSA-65 + X-Wing tokens authenticate through the standard ASP.NET Core pipeline exactly the way AddJwtBearer always has: same AuthenticationBuilder, same [Authorize], same ClaimsPrincipal. Fail-closed by construction, AOT-compatible, observable via System.Diagnostics (Metrics + ActivitySource). This is the application-layer wiring (handler, options, four event hooks, JWKS-equivalent key ring, hosted-service warmup) — NOT a cryptography library. The actual ML-DSA / X-Wing / AES-GCM work happens in PostQuantum.Jwt and the .NET 10 BCL primitives; we sit on top of them. Distributed single-use-jti enforcement available via the companion PostQuantum.AspNetCore.RedisReplayCache package. Production-quality integration for controlled issuer/verifier systems — environments where the same team owns both token issuing and validation. NOT independently audited (a permanent, documented limitation of the underlying construction — see KNOWN-GAPS.md) and not a drop-in OAuth/OIDC replacement; tokens use non-IANA algorithm identifiers and do not validate in generic JWT tooling.</Description>
    <PackageProjectUrl>https://github.com/systemslibrarian/postquantum-aspnetcore</PackageProjectUrl>
    <RepositoryUrl>https://github.com/systemslibrarian/postquantum-aspnetcore</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>jwt;jose;authentication;jwtbearer;aspnetcore;post-quantum;pqc;ml-dsa;ml-kem;x-wing;hybrid;quantum-resistant;net10</PackageTags>
    <PackageReleaseNotes>1.0.0: First stable release. The public API surface is unchanged from 1.0.0-preview.3 (enforced by package baseline validation); SemVer applies from here — PATCH for fixes, MINOR for additive surface, MAJOR for any break. The PostQuantum.Jwt engine dependency moves to its stable 1.0.0. Graduating from preview does NOT add an audit: the underlying cryptographic construction remains not independently audited — at 1.0 that is reframed from a pending gate to a permanent, documented limitation (matching the engine's 1.0.0), because an unfunded project is unlikely to secure a formal review and perpetual preview served no one. Appropriate for controlled issuer/verifier systems where you own both sides and accept that documented risk; see KNOWN-GAPS.md and SECURITY.md. Full notes: https://github.com/systemslibrarian/postquantum-aspnetcore/blob/main/CHANGELOG.md.</PackageReleaseNotes>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <Copyright>Copyright © Paul Clark</Copyright>
    <NeutralLanguage>en-US</NeutralLanguage>
  </PropertyGroup>

  <!-- Symbols + SourceLink for debuggable, reproducible packages.
       EnablePackageValidation catches accidental API breaks on subsequent versions. -->
  <PropertyGroup>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <EnablePackageValidation>true</EnablePackageValidation>
    <!-- API-surface baseline check, ON by default from 1.0.0: every pack
         compares the public API against the last published version and fails
         on an accidental break. (The old 0.1.0-preview.1 baseline was never
         published, so this used to be opt-in; 1.0.0-preview.3 is live and
         resolvable.) Bump to the newest published version at each release.
         Requires nuget.org access at pack time; override with
         -p:PackageValidationBaselineVersion= only if packing fully offline. -->
    <PackageValidationBaselineVersion>1.0.0-preview.3</PackageValidationBaselineVersion>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <InternalsVisibleTo Include="PostQuantum.AspNetCore.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="PostQuantum.Jwt" Version="1.0.0" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="\" />
    <None Include="../../LICENSE" Pack="true" PackagePath="\" />
    <None Include="../../CHANGELOG.md" Pack="true" PackagePath="\" Condition="Exists('../../CHANGELOG.md')" />
  </ItemGroup>

  <!-- Generate a CycloneDX SBOM (bom.json) inside the package on every Pack.
       Requires the `dotnet-CycloneDX` global tool (install via
       `dotnet tool install` with the `global` flag and id `CycloneDX`).
       If the tool isn't present (e.g. a fresh dev machine), pack
       continues without the SBOM rather than failing; the release
       workflow installs the tool unconditionally, so CI always produces
       the SBOM.

       The bom.json is added to the package via an in-target ItemGroup
       because $(IntermediateOutputPath)bom.json doesn't exist at the
       time a static None Include would be evaluated. -->
  <Target Name="GenerateCycloneDxSbom"
          BeforeTargets="GenerateNuspec;_GetPackageFiles"
          Condition="'$(IsPackable)' != 'false'">
    <Exec Command="dotnet CycloneDX &quot;$(MSBuildProjectFullPath)&quot; --output &quot;$(IntermediateOutputPath.TrimEnd('\').TrimEnd('/'))&quot; --filename bom.json --json"
          IgnoreExitCode="true"
          ContinueOnError="WarnAndContinue">
      <Output TaskParameter="ExitCode" PropertyName="_CycloneDxExitCode" />
    </Exec>
    <Message Importance="high"
             Text="CycloneDX SBOM not generated (tool missing or failed, exit=$(_CycloneDxExitCode)). Install with: dotnet tool install (global, id=CycloneDX)."
             Condition="'$(_CycloneDxExitCode)' != '0'" />
    <ItemGroup Condition="Exists('$(IntermediateOutputPath)bom.json')">
      <None Include="$(IntermediateOutputPath)bom.json" Pack="true" PackagePath="\" />
    </ItemGroup>
    <Message Importance="high"
             Text="CycloneDX SBOM packed into .nupkg at /bom.json"
             Condition="Exists('$(IntermediateOutputPath)bom.json')" />
  </Target>

</Project>
